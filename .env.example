# =============================================
# MCO Frontend — Variáveis de Ambiente
# Copie para .env e preencha os valores
# =============================================

# Modo desenvolvimento — bypass Azure AD
VITE_DEV_AUTH=true

# API Backend
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Supabase (PostgreSQL)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Feature flag: usar Supabase real (true) ou mocks locais (false)
VITE_USE_SUPABASE=false

# Azure AD / MSAL (ignorado se VITE_DEV_AUTH=true)
VITE_MSAL_CLIENT_ID=your-client-id-here
VITE_MSAL_AUTHORITY=https://login.microsoftonline.com/your-tenant-id
VITE_MSAL_REDIRECT_URI=http://localhost:5173
VITE_MSAL_SCOPES=api://your-client-id/.default
