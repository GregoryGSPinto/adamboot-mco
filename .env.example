# =============================================
# MCO Frontend — Variáveis de Ambiente
# Copie para .env e preencha os valores
# =============================================

# ⚠️  AVISO DE SEGURANÇA:
# NUNCA comite arquivos .env com valores reais!
# Mantenha .env no .gitignore

# =============================================
# Modo desenvolvimento — bypass Azure AD
# =============================================
# ⚠️  ATENÇÃO: VITE_DEV_AUTH=true só funciona em desenvolvimento (npm run dev)
# Em produção, esta configuração é ignorada e Azure AD é obrigatório
VITE_DEV_AUTH=false

# Credenciais de desenvolvimento (apenas quando VITE_DEV_AUTH=true)
# Configure credenciais seguras para seu ambiente local
VITE_DEV_AUTH_EMAIL=dev@local.test
VITE_DEV_AUTH_PASSWORD=change-me-in-production

# =============================================
# API Backend
# =============================================
VITE_API_BASE_URL=http://localhost:3000/api/v1

# =============================================
# Supabase (PostgreSQL)
# =============================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Feature flag: usar Supabase real (true) ou mocks locais (false)
VITE_USE_SUPABASE=false

# =============================================
# Azure AD / MSAL (obrigatório em produção)
# =============================================
VITE_MSAL_CLIENT_ID=your-client-id-here
VITE_MSAL_AUTHORITY=https://login.microsoftonline.com/your-tenant-id
VITE_MSAL_REDIRECT_URI=http://localhost:5173
VITE_MSAL_SCOPES=api://your-client-id/.default
